{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tutti.app/schemas/tutti.agent.manifest.v2.schema.json",
  "title": "Tutti Agent Extension Manifest v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "agentKey",
    "version",
    "name",
    "icon",
    "runtime",
    "profiles",
    "localizationInfo"
  ],
  "properties": {
    "schemaVersion": { "const": "tutti.agent.manifest.v2" },
    "agentKey": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
    "version": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "icon": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "src"],
      "properties": {
        "type": { "const": "asset" },
        "src": { "type": "string", "minLength": 1 }
      }
    },
    "maskIcon": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "src"],
      "properties": {
        "type": { "const": "asset" },
        "src": { "type": "string", "minLength": 1 }
      }
    },
    "heroImage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "src"],
      "properties": {
        "type": { "const": "asset" },
        "src": { "type": "string", "minLength": 1 }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "install", "launch"],
      "properties": {
        "kind": { "const": "standard-acp" },
        "install": {
          "type": "object",
          "additionalProperties": false,
          "required": ["runner", "args"],
          "properties": {
            "runner": { "enum": ["npm", "pnpm", "uv"] },
            "args": { "type": "array", "items": { "type": "string" } }
          }
        },
        "launch": {
          "type": "object",
          "additionalProperties": false,
          "required": ["executable", "args"],
          "properties": {
            "executable": { "type": "string", "minLength": 1 },
            "args": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["discovery"],
      "properties": {
        "discovery": { "type": "string" },
        "tools": { "type": "string" },
        "capabilities": { "type": "string" },
        "composer": { "type": "string" },
        "events": { "type": "string" }
      }
    },
    "localizationInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defaultLocale", "defaultFile"],
      "properties": {
        "defaultLocale": { "type": "string", "minLength": 1 },
        "defaultFile": { "type": "string", "minLength": 1 },
        "additionalLocales": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["locale", "file"],
            "properties": {
              "locale": { "type": "string", "minLength": 1 },
              "file": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
