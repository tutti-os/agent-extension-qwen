{
  "schemaVersion": "tutti.agent.manifest.v2",
  "agentKey": "qwen",
  "version": "2.0.3",
  "name": "Qwen Code",
  "description": "Qwen Code through the standard Agent Client Protocol",
  "icon": {
    "type": "asset",
    "src": "assets/icon.svg"
  },
  "maskIcon": {
    "type": "asset",
    "src": "assets/mask-icon.svg"
  },
  "heroImage": {
    "type": "asset",
    "src": "assets/hero-image.jpg"
  },
  "runtime": {
    "kind": "standard-acp",
    "install": {
      "runner": "npm",
      "args": [
        "install",
        "--prefix",
        "${installRoot}",
        "@qwen-code/qwen-code@0.19.11"
      ]
    },
    "launch": {
      "executable": "${installRoot}/node_modules/.bin/qwen",
      "args": ["--acp"]
    }
  },
  "profiles": {
    "discovery": "profiles/discovery.json",
    "tools": "profiles/tools.json",
    "capabilities": "profiles/capabilities.json",
    "composer": "profiles/composer.json"
  },
  "localizationInfo": {
    "defaultLocale": "en",
    "defaultFile": "locales/en.json",
    "additionalLocales": [
      {
        "locale": "zh-CN",
        "file": "locales/zh-CN.json"
      }
    ]
  }
}
